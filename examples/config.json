{
  "start_url": "https://example.com",
  "browser": {
    "headless": true,
    "viewport_width": 1440,
    "viewport_height": 960,
    "navigation_timeout_ms": 20000,
    "action_timeout_ms": 8000,
    "max_dom_elements": 40,
    "screenshot_full_page": false,
    "locale": "en-US",
    "timezone_id": "Asia/Shanghai"
  },
  "model": {
    "provider": "openai",
    "model": "gpt-4o",
    "replay_path": null,
    "api_key_env": "OPENAI_API_KEY",
    "base_url": null,
    "temperature": 0.2,
    "max_output_tokens": 900
  },
  "agent": {
    "max_steps": 12,
    "min_action_delay_ms": 350,
    "max_action_delay_ms": 1200,
    "low_confidence_threshold": 0.45,
    "retry_limit_per_action": 2,
    "persona": "A 68-year-old retired first-time visitor with limited patience who prefers large buttons and clear copy.",
    "goal": "Find the pricing page and try to start a free trial."
  },
  "report": {
    "output_dir": "artifacts",
    "keep_screenshots": true
  }
}
